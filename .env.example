# Core
DJANGO_SETTINGS_MODULE=nepa_unite.settings.development
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database (primary + optional replica)
DATABASE_URL=postgres://nepa:nepa@localhost:5432/nepa_unite
DATABASE_REPLICA_URL=

# Redis / Celery — OPTIONAL. If REDIS_URL is unset the app uses an in-memory
# cache and runs Celery tasks eagerly (no external Redis/worker needed).
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# CORS
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:3000

# JWT (self-issued via djangorestframework-simplejwt; signed with
# DJANGO_SECRET_KEY — no external identity provider needed). Both optional.
JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=7

# Stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_CLIENT_ID=

# Session
# Dashboard inactivity auto-logout in seconds. Default 900 = 15 min (PCI-DSS).
SESSION_INACTIVITY_TIMEOUT=900

# AWS / S3
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_INVOICES_BUCKET=nepa-unite-invoices

# Cloudinary — media storage. When set, uploaded images go to Cloudinary
# instead of the local filesystem (recommended in prod; local disk is
# ephemeral on Render). Leave blank in dev to use local MEDIA_ROOT.
CLOUDINARY_URL=

# Elasticsearch / OpenSearch
OPENSEARCH_URL=

# Email (Gmail SMTP — see README for App Password setup)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-gmail@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=your-gmail@gmail.com
