# Core
DJANGO_SETTINGS_MODULE=nepa_unite.settings.development
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database (primary + optional replica)
DATABASE_URL=postgres://nepa:nepa@localhost:5432/nepa_unite
DATABASE_REPLICA_URL=

# Redis / Celery — OPTIONAL. If REDIS_URL is unset the app uses an in-memory
# cache and runs Celery tasks eagerly (no external Redis/worker needed).
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# CORS
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:3000

# Auth0
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_AUDIENCE=https://api.nepaunite.local
AUTH0_ISSUER=https://your-tenant.us.auth0.com/
AUTH0_ALGORITHMS=RS256
AUTH0_MGMT_CLIENT_ID=
AUTH0_MGMT_CLIENT_SECRET=
AUTH0_MGMT_AUDIENCE=https://your-tenant.us.auth0.com/api/v2/

# Stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_CLIENT_ID=

# AWS / S3
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_INVOICES_BUCKET=nepa-unite-invoices

# Elasticsearch / OpenSearch
OPENSEARCH_URL=

# Email (Gmail SMTP — see README for App Password setup)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-gmail@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=your-gmail@gmail.com
